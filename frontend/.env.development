# Leave VITE_AURORA_API unset (or empty) so the app calls /api/snapshot on the same origin;
# Vite proxies /api to uvicorn (see vite.config.js). Start API: uvicorn api:app --port 8000
# For a remote API instead, use e.g. VITE_AURORA_API=http://127.0.0.1:8000

# If Windows reports WinError 10048 on port 8000, pick a free port here and match uvicorn:
# AURORA_API_PORT=8001
